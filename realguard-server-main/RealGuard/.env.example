# Flask backend
SECRET_KEY=change-me
REALGUARD_HOST=127.0.0.1
REALGUARD_PORT=5000
REALGUARD_DEVELOPER_AUTH_SECRET=change-this-shared-internal-secret

# Main MySQL database
REALGUARD_DB_HOST=127.0.0.1
REALGUARD_DB_PORT=3306
REALGUARD_DB_USER=root
REALGUARD_DB_PASSWORD=change-me
REALGUARD_DB_NAME=system

# Detection-history MySQL database
REALGUARD_DETECTION_DB_HOST=127.0.0.1
REALGUARD_DETECTION_DB_PORT=3306
REALGUARD_DETECTION_DB_USER=root
REALGUARD_DETECTION_DB_PASSWORD=change-me
REALGUARD_DETECTION_DB_NAME=image_detection

# Internal detector service used by the original V1 flow.
REALGUARD_DETECTION_BACKEND_URL=http://127.0.0.1:15000
REALGUARD_IMAGE_DETECT_FALLBACK=0
REALGUARD_V1_EXTERNAL_MIN_BYTES=104857600

# V1 admin console allowlist. Use comma-separated phone numbers or user ids.
REALGUARD_ADMIN_PHONES=
REALGUARD_ADMIN_USER_IDS=
REALGUARD_ADMIN_ALLOW_ANY_LOGIN=0
REALGUARD_ADMIN_TIMEZONE=Asia/Shanghai
REALGUARD_ADMIN_PASSWORD_MIN_LENGTH=10
REALGUARD_ADMIN_LOGIN_MAX_ATTEMPTS=5
REALGUARD_ADMIN_LOGIN_LOCK_SECONDS=600
REALGUARD_ADMIN_STATE_DB=auto
REALGUARD_BIG_SCREEN_CACHE_SECONDS=15
# Optional read-only token for /admin/screen?screenToken=... and /api/admin/big-screen.
# Prefer REALGUARD_BIG_SCREEN_TOKEN_SHA256 in production.
REALGUARD_BIG_SCREEN_TOKEN=
REALGUARD_BIG_SCREEN_TOKEN_SHA256=

# Aliyun SMS login
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sign-name
ALIYUN_SMS_TEMPLATE_CODE=your-template-code
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com/
ALIYUN_SMS_VERSION=2017-05-25
ALIYUN_SMS_COUNTRY_CODE=86

# Aliyun Green image forensics. Use a RAM user with the minimum required
# permissions. Do not reuse the SMS key unless the same RAM policy is intended.
ALIBABA_CLOUD_ACCESS_KEY_ID=your-green-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-green-access-key-secret
REALGUARD_ALIYUN_GREEN_ENDPOINT=green-cip.cn-beijing.aliyuncs.com
REALGUARD_PUBLIC_BASE_URL=https://your-public-realguard-host

# Optional LLM config for legacy Agent helpers.
REALGUARD_LLM_API_KEY=your-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
