# Flask backend
SECRET_KEY=replace-with-at-least-32-random-bytes
REALGUARD_HOST=127.0.0.1
REALGUARD_PORT=5000
REALGUARD_DEVELOPER_AUTH_SECRET=change-this-shared-internal-secret
# Stable secret used only to derive replayable API keys for Idempotency-Key.
# Do not rotate it together with REALGUARD_DEVELOPER_AUTH_SECRET.
REALGUARD_DEVELOPER_IDEMPOTENCY_SECRET=change-this-stable-idempotency-secret
REALGUARD_SECURITY_AUDIT_HMAC_KEY=replace-with-a-separate-random-64-hex-character-key
REALGUARD_SECURITY_AUDIT_HMAC_KEY_ID=v1
REALGUARD_SECURITY_AUDIT_HMAC_KEYS_JSON={}
REALGUARD_PRIVACY_ERASURE_LEDGER_PATH=/opt/realguard-data/privacy-erasure/privacy-erasure-tombstones.sqlite3
REALGUARD_SECURITY_AUDIT_CHECKPOINT_FILE=/opt/realguard-audit-checkpoint/checkpoint.json
REALGUARD_DEVELOPER_FREE_CALLS=100
REALGUARD_DEVELOPER_MAX_IMAGE_BYTES=26214400
REALGUARD_DEVELOPER_MAX_IMAGE_PIXELS=24000000
REALGUARD_DEVELOPER_TASK_MAX_PENDING=50
REALGUARD_WEB_ACCOUNT_TASK_MAX_PENDING=20
REALGUARD_WEB_ACCOUNT_OWNER_MAX_PENDING=3
REALGUARD_WEB_GUEST_TASK_MAX_PENDING=5
REALGUARD_WEB_GUEST_OWNER_MAX_PENDING=1
REALGUARD_WEB_GUEST_DAILY_GLOBAL_LIMIT=500
REALGUARD_DEVELOPER_SPOOL_MAX_BYTES=2147483648
REALGUARD_DEVELOPER_WORKER_CONCURRENCY=2
REALGUARD_WEB_WORKER_CONCURRENCY=1
REALGUARD_API_WORKER_CONCURRENCY=1
REALGUARD_WEB_TASK_SPOOL_ROOT=/opt/realguard-data/web-spool
REALGUARD_WEB_TASK_LEASE_SECONDS=600
REALGUARD_WEB_TASK_HEARTBEAT_SECONDS=30
REALGUARD_WEB_TASK_MAX_ATTEMPTS=3
REALGUARD_MAX_IMAGE_UPLOAD_BYTES=26214400
REALGUARD_MAX_IMAGE_SOURCE_PIXELS=24000000
REALGUARD_BACKGROUND_JOB_CAPACITY=2
REALGUARD_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128
REALGUARD_TERMS_VERSION=2026-07-15
REALGUARD_TERMS_SHA256=09707ba3b915db9904cc6f8b4951b5c9bbfff7e768fd237c04eedf90fef89ff
REALGUARD_PRIVACY_SHA256=cdf839825c20ce283ed76944aba09c5c2962abfb05592244004489b73fae80bb
REALGUARD_CONSENT_AUDIT_SALT=replace-with-a-random-private-salt
REALGUARD_SESSION_ABSOLUTE_MAX_AGE=604800
# Independent HMAC key for signed V1 image evidence manifests. Generate with:
# openssl rand -hex 32
REALGUARD_EVIDENCE_HMAC_KEY=replace-with-an-independent-random-64-hex-character-key
REALGUARD_EVIDENCE_HMAC_KEY_ID=v1
# Historical verification-only keys used after active-key rotation. Keep this
# JSON on one line; when sourced by a shell env file, wrap it in single quotes.
# Example: REALGUARD_EVIDENCE_HMAC_KEYS_JSON='{"v1":"old-key-at-least-32-bytes-0123456789"}'
REALGUARD_EVIDENCE_HMAC_KEYS_JSON={}
REALGUARD_DB_CONNECT_TIMEOUT=5
REALGUARD_DB_READ_TIMEOUT=30
REALGUARD_DB_WRITE_TIMEOUT=30
REALGUARD_DETECTION_DB_CONNECT_TIMEOUT=5
REALGUARD_DETECTION_DB_READ_TIMEOUT=30
REALGUARD_DETECTION_DB_WRITE_TIMEOUT=30
REALGUARD_ADMIN_STATE_PATH=/opt/realguard-data/admin_state.json
# Administrator-only evaluation datasets, run history, and load-test metrics.
REALGUARD_INTERNAL_TEST_ROOT=/opt/realguard-data/internal-testing
REALGUARD_INTERNAL_TEST_DB=/opt/realguard-data/internal-testing/internal-testing.sqlite3
REALGUARD_INTERNAL_TEST_MAX_DATASETS=200
REALGUARD_INTERNAL_TEST_MAX_BYTES=10737418240
REALGUARD_EVIDENCE_POLICY_VERSION=huijian-v1-image-report-policy-v1
REALGUARD_EVIDENCE_SNAPSHOT_ROOT=/opt/realguard-data/evidence-manifests
# Backup status is non-secret. Put rclone credentials in /etc/realguard/backup.env.
REALGUARD_BACKUP_STATUS_FILE=/opt/realguard-data/backup-status.json
REALGUARD_BACKUP_MAX_AGE_SECONDS=129600
REALGUARD_BACKUP_REQUIRE_OFFSITE=1
REALGUARD_BACKUP_REQUIRE_ALL_SOURCES=1
# Optional colon-separated trusted static roots when originals live outside this checkout.
REALGUARD_EVIDENCE_SOURCE_ROOTS=
# Prices use integer fen. Keep paid billing disabled until prices and manual recharge are ready.
REALGUARD_DEVELOPER_FAST_PRICE_FEN=0
REALGUARD_DEVELOPER_SWARM_PRICE_FEN=0
REALGUARD_DEVELOPER_FAST_BILLING_ENABLED=0
REALGUARD_DEVELOPER_SWARM_BILLING_ENABLED=0

# Main MySQL database
REALGUARD_DB_HOST=127.0.0.1
REALGUARD_DB_PORT=3306
REALGUARD_DB_USER=realguard_app
REALGUARD_DB_PASSWORD=change-me
REALGUARD_DB_NAME=system

# Detection-history MySQL database
REALGUARD_DETECTION_DB_HOST=127.0.0.1
REALGUARD_DETECTION_DB_PORT=3306
REALGUARD_DETECTION_DB_USER=realguard_detection
REALGUARD_DETECTION_DB_PASSWORD=change-me
REALGUARD_DETECTION_DB_NAME=image_detection

# Internal detector service used by the original V1 flow.
REALGUARD_DETECTION_BACKEND_URL=http://127.0.0.1:15001
REALGUARD_DETECTOR_INTERNAL_TOKEN=replace-with-a-random-private-token
REALGUARD_IMAGE_DETECT_FALLBACK=0
REALGUARD_V1_EXTERNAL_MIN_BYTES=104857600
# GPU model service retries transient overloads only; total attempts stay bounded.
REALGUARD_REMOTE_INFERENCE_MAX_ATTEMPTS=3
REALGUARD_REMOTE_INFERENCE_RETRY_MAX_DELAY=5
REALGUARD_LLM_TIMEOUT=20
REALGUARD_REMOTE_INFERENCE_TOTAL_TIMEOUT=150
REALGUARD_REMOTE_REQUIRE_RESPONSE_INTEGRITY=1
REALGUARD_REMOTE_RESPONSE_MAX_AGE_SECONDS=300
REALGUARD_MODEL_INTERNAL_TOKEN=replace-with-a-random-private-token-at-least-32-characters
REALGUARD_MODEL_INTERNAL_TOKEN_PREVIOUS=
REALGUARD_MODEL_RESPONSE_HMAC_KEY=replace-with-64-lowercase-hex-characters
REALGUARD_MODEL_RESPONSE_HMAC_KEY_ID=v1
# Verification-only historical response keys retained during and after rotation.
# Example: REALGUARD_MODEL_RESPONSE_HMAC_KEYS_JSON='{"v1":"old-64-hex-key"}'
REALGUARD_MODEL_RESPONSE_HMAC_KEYS_JSON={}
# The Web process re-verifies the GPU calibration envelope with this fixed key.
REALGUARD_V2_CALIBRATION_PUBLIC_KEY_FILE=/etc/realguard/model-calibration-ed25519.pub
REALGUARD_V2_CALIBRATION_REQUIRE_ROOT_OWNERSHIP=1

# V1 admin console allowlist. Use comma-separated phone numbers or user ids.
REALGUARD_ADMIN_PHONES=
REALGUARD_ADMIN_USER_IDS=
# Deprecated and ignored. Create the first administrator with `flask create-admin`.
REALGUARD_ADMIN_ALLOW_ANY_LOGIN=0
REALGUARD_ADMIN_TIMEZONE=Asia/Shanghai
REALGUARD_ADMIN_PASSWORD_MIN_LENGTH=10
REALGUARD_ADMIN_LOGIN_MAX_ATTEMPTS=5
REALGUARD_ADMIN_LOGIN_LOCK_SECONDS=600
REALGUARD_ADMIN_STATE_DB=auto
REALGUARD_BIG_SCREEN_CACHE_SECONDS=15
# Optional read-only token for /admin/screen?screenToken=... and /api/admin/big-screen.
# Prefer REALGUARD_BIG_SCREEN_TOKEN_SHA256 in production.
REALGUARD_BIG_SCREEN_TOKEN=
REALGUARD_BIG_SCREEN_TOKEN_SHA256=

# Aliyun SMS login
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sign-name
ALIYUN_SMS_TEMPLATE_CODE=your-template-code
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com/
ALIYUN_SMS_VERSION=2017-05-25
ALIYUN_SMS_COUNTRY_CODE=86

# Aliyun Green image forensics. Use a RAM user with the minimum required
# permissions. Do not reuse the SMS key unless the same RAM policy is intended.
ALIBABA_CLOUD_ACCESS_KEY_ID=your-green-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-green-access-key-secret
REALGUARD_ALIYUN_GREEN_ENDPOINT=green-cip.cn-beijing.aliyuncs.com
REALGUARD_PUBLIC_BASE_URL=https://your-public-realguard-host

# Optional LLM config for legacy Agent helpers.
REALGUARD_LLM_API_KEY=your-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
