DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen3-vl-flash
JIANZHEN_ACCESS_TOKEN=
JIANZHEN_REQUIRE_DEVELOPER_API_KEY=true
JIANZHEN_DEVELOPER_AUTH_URL=http://127.0.0.1:5000/api/developer/keys/verify
REALGUARD_DEVELOPER_AUTH_SECRET=change-this-shared-internal-secret

# SQLite persistence for history, analysis cache, and lightweight metrics.
JIANZHEN_DATA_DIR=/opt/jianzhen-v2/data
JIANZHEN_IMAGE_SUSPECT_THRESHOLD=0.62
JIANZHEN_IMAGE_HIGH_THRESHOLD=0.82
JIANZHEN_IMAGE_REGION_THRESHOLD=0.72
JIANZHEN_IMAGE_AUXILIARY_WEIGHT=0.20
JIANZHEN_IMAGE_AUXILIARY_DISPLAY_CAP=0.35

# Optional: Google Gemini SynthID watermark evidence.
# Only the detection path is used; watermark removal/bypass code is not called.
SYNTHID_ENABLED=false
SYNTHID_REPO_PATH=/opt/reverse-SynthID
SYNTHID_CODEBOOK_PATH=/opt/reverse-SynthID/artifacts/spectral_codebook_v4.npz
SYNTHID_MODEL_PROFILE=gemini-3.1-flash-image-preview

# Optional: visible AI watermark detection-only module.
# Uses template/NCC localization for Gemini-family visible sparkle and a generic corner-overlay heuristic.
VISIBLE_WATERMARK_ENABLED=true
VISIBLE_WATERMARK_GEMINI_CONFIDENCE_THRESHOLD=0.72
VISIBLE_WATERMARK_GEMINI_SPATIAL_THRESHOLD=0.62
VISIBLE_WATERMARK_GEMINI_GRADIENT_THRESHOLD=0.35
VISIBLE_WATERMARK_GENERIC_CORNER_THRESHOLD=0.84
VISIBLE_WATERMARK_GENERIC_IMAGE_ENABLED=false
