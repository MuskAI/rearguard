DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen3-vl-flash
JIANZHEN_ACCESS_TOKEN=
# Separate break-glass token for health, metrics, and cross-tenant admin APIs.
# Never reuse JIANZHEN_ACCESS_TOKEN here.
JIANZHEN_ADMIN_ACCESS_TOKEN=
# Production defaults to authenticated detection. Set this only for isolated
# local demos; public hosts must keep it false.
JIANZHEN_ALLOW_ANONYMOUS_DETECT=false
JIANZHEN_ALLOW_DIRECT_DEVELOPER_KEYS=false
JIANZHEN_DEVELOPER_AUTH_URL=http://127.0.0.1:5000/api/developer/keys/verify
REALGUARD_DEVELOPER_AUTH_SECRET=change-this-shared-internal-secret
# Independent signing key for expiring public report links. Do not reuse any
# access, admin, session, or developer authentication secret.
JIANZHEN_REPORT_SHARE_SECRET=replace-with-a-random-independent-secret
JIANZHEN_REPORT_SHARE_DEFAULT_SECONDS=604800
JIANZHEN_REPORT_SHARE_MAX_SECONDS=2592000

# SQLite persistence for history, analysis cache, and lightweight metrics.
JIANZHEN_DATA_DIR=/opt/jianzhen-v2/data
JIANZHEN_IMAGE_SUSPECT_THRESHOLD=0.62
JIANZHEN_IMAGE_HIGH_THRESHOLD=0.82
JIANZHEN_IMAGE_REGION_THRESHOLD=0.72
JIANZHEN_IMAGE_AUXILIARY_WEIGHT=0.20
JIANZHEN_IMAGE_AUXILIARY_DISPLAY_CAP=0.35
JIANZHEN_ANALYSIS_CACHE_VERSION=v8-provenance-first
JIANZHEN_REQUEST_EVENT_RETENTION_DAYS=90
JIANZHEN_TOKEN_USAGE_RETENTION_DAYS=730

# Provenance-first detector on the 66 server. It is reached through a
# loopback-only reverse SSH tunnel on the public host.
JIANZHEN_PROVENANCE_PRECHECK_URL=http://127.0.0.1:15066
JIANZHEN_PROVENANCE_PRECHECK_TOKEN=replace-with-the-shared-precheck-token
JIANZHEN_PROVENANCE_PRECHECK_TIMEOUT=8
JIANZHEN_PROVENANCE_PRECHECK_ORIGINAL_TIMEOUT=20
JIANZHEN_PROVENANCE_PRECHECK_DIRECT_UPLOAD_MAX_BYTES=1572864
JIANZHEN_PROVENANCE_PRECHECK_SCAN_MAX_SIDE=1536
JIANZHEN_PROVENANCE_PRECHECK_SCAN_QUALITY=94

# Optional: Google Gemini SynthID watermark evidence.
# Only the detection path is used; watermark removal/bypass code is not called.
SYNTHID_ENABLED=false
SYNTHID_REPO_PATH=/opt/reverse-SynthID
SYNTHID_CODEBOOK_PATH=/opt/reverse-SynthID/artifacts/spectral_codebook_v4.npz
SYNTHID_MODEL_PROFILES=auto
SYNTHID_POSSIBLE_THRESHOLD=0.53
SYNTHID_DETECTION_THRESHOLD=0.75
SYNTHID_ATTRIBUTION_MARGIN=0.08
SYNTHID_PROFILE_CACHE_SIZE=2

# Optional: visible AI watermark detection-only module.
# Uses template/NCC localization for Gemini-family visible sparkle and a generic corner-overlay heuristic.
VISIBLE_WATERMARK_ENABLED=true
VISIBLE_WATERMARK_GEMINI_CONFIDENCE_THRESHOLD=0.72
VISIBLE_WATERMARK_GEMINI_SPATIAL_THRESHOLD=0.62
VISIBLE_WATERMARK_GEMINI_GRADIENT_THRESHOLD=0.35
VISIBLE_WATERMARK_GENERIC_CORNER_THRESHOLD=0.84
VISIBLE_WATERMARK_GENERIC_IMAGE_ENABLED=false
