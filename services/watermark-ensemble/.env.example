WATERMARK_ENSEMBLE_TOKEN=replace-with-a-long-random-token
WATERMARK_OCR_ENABLED=true
WATERMARK_RETRIEVAL_ENABLED=true
WATERMARK_RETRIEVAL_BACKEND=faiss_clip
WATERMARK_CLIP_MODEL=openai/clip-vit-base-patch32
WATERMARK_CLIP_DEVICE=auto
WATERMARK_RETRIEVAL_THRESHOLD=0.82
WATERMARK_RETRIEVAL_INDEX_DIR=/home/ymk/services/watermark-ensemble/retrieval
WATERMARK_EVIDENCE_WORKERS=2
WATERMARK_GALLERY_DIR=/home/ymk/services/watermark-ensemble/gallery
