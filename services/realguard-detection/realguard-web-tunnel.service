[Unit]
Description=RealGuard GPU inference tunnel to the public application server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ymk
ExecStart=/usr/bin/ssh -N -T -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o StrictHostKeyChecking=accept-new -i /home/ymk/.ssh/realguard_web_tunnel_ed25519 -R 127.0.0.1:15000:127.0.0.1:5000 ubuntu@124.221.92.85
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
